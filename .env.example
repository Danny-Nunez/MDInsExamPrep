# Google Analytics (default G-P95DGK7KB4 — loaded site-wide from app/layout.tsx)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-P95DGK7KB4
# NEXT_PUBLIC_GA_DISABLED=true

OPENAI_API_KEY=sk-your-key-here
# Optional: model for npm run batch:prometric:* (default gpt-4o-mini)
# BATCH_MODEL=gpt-4o-mini

# MongoDB Atlas — required on Vercel (Project Settings → Environment Variables)
# Use the full connection string from Atlas → Connect → Drivers → Node.js
# If your password has special characters (@, #, :, /, etc.), URL-encode them.
# Same URI for the Next.js app and local scripts (npm run mongo:ping, batch:*).
# Scripts auto-derive a non-SRV connection from this when Mac DNS blocks mongodb+srv://
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Only if auto-derive fails — optional override (usually not needed):
# MONGO_URI_STANDARD=mongodb://user:password@host1:27017,host2:27017/?ssl=true&replicaSet=...

# Atlas → Network Access: allow 0.0.0.0/0 (Vercel uses dynamic IPs)
# If SSL errors persist on Vercel, try Atlas "Connect" → "Drivers" → copy the
# non-SRV connection string (lists hostnames explicitly) instead of mongodb+srv://

AUTH_SECRET=generate-a-long-random-string-at-least-32-chars

# Comma-separated emails allowed to use /admin + full app without subscribing.
# Also set on Vercel Production. Or run: npm run set-admin -- you@example.com
ADMIN_EMAILS=you@example.com

# Stripe — subscription checkout ($20/month price in Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Real Price ID from Stripe → Products → Pricing (NOT the literal "price_..." placeholder)
STRIPE_PRICE_ID=price_1xxxxxxxxxxxx

# Public site URL (Stripe redirects; also used for sitemap/robots when not localhost)
# Production: https://marylandinsuranceexam.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
